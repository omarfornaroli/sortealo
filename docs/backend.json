
{
  "entities": {
    "Raffle": {
      "title": "Raffle",
      "description": "Represents a raffle sweepstake event.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "prize": { "type": "string" },
        "ticketPrice": { "type": "number" },
        "maxTickets": { "type": "number" },
        "soldTickets": { "type": "number" },
        "drawDate": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "ticketPrice", "maxTickets", "drawDate"]
    },
    "AdminSettings": {
      "title": "Admin Settings",
      "description": "System settings for administration.",
      "type": "object",
      "properties": {
        "isInitialized": { "type": "boolean" },
        "setupDate": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/raffles/{raffleId}": {
      "schema": "Raffle",
      "description": "Collection of available raffles."
    },
    "/settings/admin": {
      "schema": "AdminSettings",
      "description": "Global admin configuration."
    }
  }
}
